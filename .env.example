# Discord
DISCORD_TOKEN=your_discord_user_token_here
DISCORD_PREFIX=?

# Whitelist (comma separated user IDs). Kosongkan = semua user boleh pakai
ALLOWED_USERS=

# Path yt-dlp (opsional, default cari di PATH)
YTDLP_PATH=

# Stealth mode (true = tampak lebih manusiawi, default true)
STEALTH=true

# Channel info: maksimal durasi 1 lagu dalam detik
MAX_SONG_DURATION=1800

# State file (resume otomatis setelah restart)
STATE_FILE=./data/state.json

# Default DM reply (true = balas ke DM, false = balas di channel)
REPLY_DM=true
